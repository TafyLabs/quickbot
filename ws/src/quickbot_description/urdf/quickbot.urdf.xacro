<?xml version="1.0"?>
<!-- QuickBot URDF: Create 2 base + Pi 5 + D455 mount.
     Frames per docs/architecture.md.  Geometry is intentionally rough — refine
     once the real chassis is measured. -->
<robot name="quickbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="base_radius" value="0.17"/>      <!-- Create 2 is ~34 cm diameter -->
  <xacro:property name="base_height" value="0.09"/>
  <xacro:property name="wheel_separation" value="0.235"/>

  <xacro:property name="camera_x" value="0.10"/>          <!-- D455 forward offset from base center -->
  <xacro:property name="camera_z" value="0.18"/>          <!-- D455 height above floor -->
  <xacro:property name="camera_pitch" value="0.0"/>       <!-- tilt forward (rad), set positive for downward -->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="create_white">
        <color rgba="0.9 0.9 0.9 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.034" rpy="0 0 0"/>  <!-- wheel radius -->
  </joint>

  <link name="camera_link"/>
  <joint name="base_link_to_camera_link" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 ${camera_pitch} 0"/>
  </joint>

  <!-- RealSense optical frame conventions: x right, y down, z forward. -->
  <link name="camera_depth_optical_frame"/>
  <joint name="camera_link_to_depth_optical" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>

</robot>
